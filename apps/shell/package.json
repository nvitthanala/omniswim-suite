{
  "name": "@omniswim/shell",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/free-port.mjs && node ../../scripts/clear-vite-cache.mjs",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.js",
    "prestart": "node ../../scripts/free-port.mjs && npm run build",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@omniswim/core": "*",
    "@omniswim/db": "*",
    "@omniswim/manager": "*",
    "@omniswim/matrix": "*",
    "@omniswim/metrics": "*",
    "@omniswim/ui": "*",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.62.7",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
